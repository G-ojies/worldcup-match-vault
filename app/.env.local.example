# Copy to .env.local and adjust for your environment.

# RPC endpoint the dApp talks to (localnet by default; use a devnet URL to demo).
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8899

# Program id. Defaults to the address baked into the IDL if unset.
NEXT_PUBLIC_PROGRAM_ID=E5ffcawirq6hVse98NJVDGQ4RSkkNAYWzN2RNoRAikzJ

# Optional: restrict the "Create market" button to a single admin wallet.
# If unset, any connected wallet can create markets.
NEXT_PUBLIC_ADMIN_PUBKEY=

# Optional: a free key from https://www.football-data.org/ for live fixtures.
# Without it the mock oracle falls back to hardcoded matches.
NEXT_PUBLIC_FOOTBALL_DATA_KEY=
